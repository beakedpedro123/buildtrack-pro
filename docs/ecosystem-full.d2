direction: down

title: BuildTrack Pro - Full System Ecosystem (v6 Hardened)

# ============================================================
# CLIENT LAYER
# ============================================================
clients: "Client Platforms" {
  style.fill: "#1a1a2e"
  style.stroke: "#C9A84C"

  mobile: "📱 Mobile App\n(Expo / React Native)" {
    style.fill: "#16213e"
    style.stroke: "#C9A84C"
  }
  web: "🌐 Web App\n(Metro Bundler)" {
    style.fill: "#16213e"
    style.stroke: "#C9A84C"
  }
  apk: "📦 Android APK\n(Production Build)" {
    style.fill: "#16213e"
    style.stroke: "#C9A84C"
  }
}

# ============================================================
# APP MODULES (TABS)
# ============================================================
app_modules: "App Modules (Tabs)" {
  style.fill: "#0d1b2a"
  style.stroke: "#48dbfb"

  home: "🏠 Home Dashboard\nJob Overview • Weather\nDaily Messages • Quick Actions" {
