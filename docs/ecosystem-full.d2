    style.stroke: "#48dbfb"
  }
  team: "👷 Team Management\nEmployee Profiles\nRole Assignment\nSalary Distribution" {
    style.fill: "#1b2838"
    style.stroke: "#48dbfb"
  }
  jobs: "🏗️ Jobs & Projects\nBudget Tracking\nStatus Management\nCost Allocation" {
    style.fill: "#1b2838"
    style.stroke: "#48dbfb"
  }
  meetings: "📋 Meetings & Goals\nSafety Toolbox\nDaily Goals\nVoice Recording\nTranscription" {
    style.fill: "#1b2838"
    style.stroke: "#48dbfb"
  }
  safety: "🦺 Safety\nToolbox Talks\nTopics Library\nCompliance Tracking" {
    style.fill: "#1b2838"
    style.stroke: "#48dbfb"
  }
  reports: "📊 Field Reports\nDaily Logs\nWeather Data\nPhoto Documentation" {
    style.fill: "#1b2838"
    style.stroke: "#48dbfb"
  }
  kpis: "📈 KPIs\nPerformance Metrics\nGoal Tracking\nProgress Charts" {
    style.fill: "#1b2838"
    style.stroke: "#48dbfb"
  }
  labor: "💰 Labor Costs\nJob Costing\nBudget vs Actual\nFinancial Graphs" {
    style.fill: "#1b2838"
    style.stroke: "#48dbfb"
  }
  profile: "👤 Profile & Settings\nBranding\nTrade Config\nCompany Setup" {
    style.fill: "#1b2838"
    style.stroke: "#48dbfb"
  }
}

# ============================================================
# PIVOT AI
# ============================================================
pivot: "🤖 Pivot AI Assistant" {
  style.fill: "#2d1b69"
  style.stroke: "#a29bfe"

  llm: "LLM Engine\nMultimodal AI\nText + Image + Audio" {
    style.fill: "#3d2b79"
    style.stroke: "#a29bfe"
  }
  voice: "Voice Input\nSpeech-to-Text\nMicrophone Access" {
    style.fill: "#3d2b79"
    style.stroke: "#a29bfe"
  }
  knowledge: "Knowledge Base\nFraming & Steel\nUtah Codes\nConstruction Math" {
    style.fill: "#3d2b79"
    style.stroke: "#a29bfe"
  }
  scheduling: "Smart Scheduling\nGoal Generation\nDeadline Setting" {
    style.fill: "#3d2b79"
    style.stroke: "#a29bfe"
  }
}

# ============================================================
# SECURITY LAYER
# ============================================================
security: "🛡️ Security Layer (28 Controls)" {
  style.fill: "#1a0000"
  style.stroke: "#e94560"

  edge: "Edge Protection\nHelmet.js • CSP Nonce\nCORS • Rate Limiting\n(Global + Per-User)" {
    style.fill: "#2a0a0a"
    style.stroke: "#e94560"
  }
  auth: "Authentication\nPIN + bcrypt\nSession Cookies (HttpOnly)\nOAuth Flow" {
    style.fill: "#2a0a0a"
    style.stroke: "#e94560"
  }
  rbac: "Authorization (RBAC)\nOwner • Office Manager\nLogistics • Foreman • Laborer\nassertRole Guards" {
    style.fill: "#2a0a0a"
    style.stroke: "#e94560"
  }
  validation: "Input Validation\nZod Schemas\nPrompt Length Cap (2000)\nFile Type + Size Limits" {
    style.fill: "#2a0a0a"
    style.stroke: "#e94560"
  }
  monitoring: "Monitoring & Audit\nCSP Violation Reports\nWrite Audit Log\nRequest Logger" {
    style.fill: "#2a0a0a"
    style.stroke: "#e94560"
  }
}

# ============================================================
# API LAYER
# ============================================================
api: "⚡ API Server (Express + tRPC)" {
  style.fill: "#1a1a2e"
  style.stroke: "#feca57"

  trpc: "tRPC Router\nType-Safe Procedures\n40+ Endpoints" {
    style.fill: "#2a2a3e"
    style.stroke: "#feca57"
  }
  pdf_gen: "PDF Generation\nPayroll Reports\nBudget Reports\nField Reports\nJob Completion" {
    style.fill: "#2a2a3e"
    style.stroke: "#feca57"
  }
  email_svc: "Email Service\nReport Delivery\nNotifications" {
    style.fill: "#2a2a3e"
    style.stroke: "#feca57"
  }
  push: "Push Notifications\nExpo Push API\nEvent-Driven Alerts" {
    style.fill: "#2a2a3e"
    style.stroke: "#feca57"
  }
}

# ============================================================
# DATA LAYER
# ============================================================
data: "🗄️ Data Layer" {
  style.fill: "#0a1628"
  style.stroke: "#00d2d3"

  postgres: "PostgreSQL Database\nDrizzle ORM\nParameterized Queries\n25+ Tables" {
    style.fill: "#0f2038"
    style.stroke: "#00d2d3"
  }
  tables: "Core Tables\nemployees • jobs • clock_entries\npayroll_periods • field_reports\nsafety_meetings • kpis\ngoals • expenses • trades" {
    style.fill: "#0f2038"
    style.stroke: "#00d2d3"
  }
  audit_tables: "Audit Tables\ndata_audit_log\nwebhook_events\n(Forensic Traceability)" {
    style.fill: "#0f2038"
    style.stroke: "#ff6b6b"
  }
  s3: "S3 File Storage\nSigned Upload URLs\nPhotos • Documents\nVoice Recordings" {
    style.fill: "#0f2038"
    style.stroke: "#00d2d3"
  }
}

# ============================================================
# EXTERNAL INTEGRATIONS
# ============================================================
external: "🌍 External Services" {
  style.fill: "#1b2838"
  style.stroke: "#ff9f43"

  stripe: "💳 Stripe\nSubscription Billing\nWebhook Verification\nIdempotency Keys" {
    style.fill: "#2b3848"
    style.stroke: "#ff9f43"
  }
  weather: "🌤️ Weather API\nJob Site Conditions\nField Report Data" {
    style.fill: "#2b3848"
    style.stroke: "#ff9f43"
  }
  expo_push: "📲 Expo Push\nMobile Notifications\nCrew Alerts" {
    style.fill: "#2b3848"
    style.stroke: "#ff9f43"
  }
  ai_provider: "🧠 AI Provider\nLLM Backend\nImage Recognition\nVoice Transcription" {
    style.fill: "#2b3848"
    style.stroke: "#a29bfe"
  }
}

# ============================================================
# CONNECTIONS
# ============================================================

# Client to App Modules
clients.mobile -> app_modules
clients.web -> app_modules
clients.apk -> app_modules

# App Modules to Pivot (AI accessible from all screens)
app_modules.home -> pivot: "AI Button"
app_modules.meetings -> pivot: "Voice → Goals"
app_modules.clock -> pivot
app_modules.jobs -> pivot: "Cost Calcs"
app_modules.labor -> pivot: "Financial Analysis"
app_modules.kpis -> pivot: "KPI Generation"
app_modules.safety -> pivot: "Topic Generation"

# All traffic through Security
app_modules -> security.edge: "All Requests"
pivot -> security.edge: "AI Requests"

# Security to API
security.edge -> security.auth
security.auth -> security.rbac
security.rbac -> security.validation
security.validation -> api.trpc

# API internal
api.trpc -> api.pdf_gen: "Report Generation"
api.trpc -> api.email_svc: "Email Delivery"
api.trpc -> api.push: "Push Alerts"

# API to Data
api.trpc -> data.postgres: "CRUD Operations"
data.postgres -> data.tables
data.postgres -> data.audit_tables: "All Writes Logged"
api.trpc -> data.s3: "File Operations"

# API to External
api.trpc -> external.stripe: "Billing"
api.trpc -> external.weather: "Weather Data"
api.push -> external.expo_push: "Deliver Notifications"
pivot.llm -> external.ai_provider: "AI Inference"

# Stripe webhook back
external.stripe -> api.trpc: "Webhooks\n(Signature Verified)"

# Monitoring
security.monitoring -> data.audit_tables: "Audit Records"

# Pivot knowledge
pivot.knowledge -> data.postgres: "Learn from Data"
pivot.voice -> external.ai_provider: "Transcription"
