{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NODE_ENV": "development",
        "ANDROID_MIN_SDK_VERSION": "24"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "NODE_ENV": "production",
        "ANDROID_MIN_SDK_VERSION": "24"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "NODE_ENV": "production",
        "ANDROID_MIN_SDK_VERSION": "24"
      },
      "ios": {
        "image": "latest"
      },
      "android": {
        "image": "latest",
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PminSdkVersion=24"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "pedrocarranza@yahoo.com",
        "ascAppId": "6760992281",
        "appleTeamId": "S6XJBXT6HM"
      }
    }
  }
}
